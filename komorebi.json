{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.41/schema.json",
  "app_specific_configuration_path": "$Env:USERPROFILE/applications.json",
  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",
  "default_workspace_padding": 10,
  "default_container_padding": 10,
  "border": true,
  "border_width": 5,
  "border_offset": -1,
  "font_family": "JetBrains Mono",
  "theme": {
    "palette": "Base16",
    "name": "AtelierEstuary",
    "bar_accent": "Base0C"
  },
  "stackbar": {
    "height": 40,
    "mode": "OnStack",
    "tabs": {
      "width": 300
    }
  },
  "monitors": [
    {
      "workspaces": [
        {
          "name": "Web",
          "layout": "BSP",
          "initial_workspace_rules": [
            {
              "kind": "Exe",
              "id": "firefox.exe"
            }
          ]
        },
        {
          "name": "Game",
          "initial_workspace_rules": [
            {
              "kind": "Exe",
              "id": "Playnite.DesktopApp.exe"
            },
            {
              "kind": "Exe",
              "id": "steamwebhelper.exe"
            },
            {
              "kind": "Exe",
              "id": "GalaxyClient.exe"
            },
            {
              "kind": "Exe",
              "id": "EpicGamesLauncher.exe"
            },
            {
              "kind": "Exe",
              "id": "EADesktop.exe"
            },
            {
              "kind": "Exe",
              "id": "Amazon Games UI.exe"
            }
          ]
        },
        {
          "name": "Pim",
          "layout": "BSP",
          "initial_workspace_rules": [
            {
              "kind": "Exe",
              "id": "Joplin.exe"
            },
            {
              "kind": "Exe",
              "id": "thunderbird.exe"
            },
            {
              "kind": "Exe",
              "id": "kmymoney.exe"
            },
            {
              "kind": "Exe",
              "id": "soffice.bin"
            }
          ]
        },
        {
          "name": "Media",
          "layout": "BSP",
          "initial_workspace_rules": [
            {
              "kind": "Exe",
              "id": "vlc.exe"
            },
            {
              "kind": "Exe",
              "id": "Spotify.exe"
            },
            {
              "kind": "Title",
              "id": "SoundCloud",
              "matching_strategy": "Contains"
            },
            {
              "kind": "Exe",
              "id": "calibre.exe"
            }
          ]
        }
      ]
    }
  ],
  "tray_and_multi_window_applications": [
    {
      "kind": "Exe",
      "id": "EADesktop.exe"
    },
    {
      "kind": "Exe",
      "id": "Playnite.DesktopApp.exe"
    },
    {
      "kind": "Exe",
      "id": "kmymoney.exe"
    },
    {
      "kind": "Exe",
      "id": "Joplin.exe"
    }
  ],
  "ignore_rules": [
  ],
  "object_name_change_applications": [
    {
      "id": "soffice.bin",
      "kind": "Exe",
      "matching_strategy": "Equals"
    }
  ],
  "floating_applications": [
    {
      "kind": "Exe",
      "id": "WindowsTerminal.exe"
    },
    {
      "kind": "Exe",
      "id": "explorer.exe"
    },
    {
      "kind": "Exe",
      "id": "SumatraPDF.exe"
    },
    {
      "kind": "Exe",
      "id": "neovide.exe"
    },
    {
      "kind": "Exe",
      "id": "7zFM.exe"
    },
    {
      "kind": "Exe",
      "id": "WinSCP.exe"
    },
    {
      "kind": "Exe",
      "id": "Bitwarden.exe"
    }
  ]
}
